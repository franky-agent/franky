FROM docker/sandbox-templates:claude-code
ARG TARGETOS
ARG TARGETARCH
ARG TARGETVARIANT
USER root
#  Install libbtrfs-dev libgpgme-dev needed by podman for https://github.com/containifyci/engine-ci 
# linux-tools-common needed for perf (CPU profiling), heaptrack (Memory profiling), cargo needed for inferno (CPU and Memory profiling reporting)
# xxd tool multiple times deepseek tried to use xxd 
RUN sudo apt-get update && \
    sudo apt-get install -y wget gnupg podman xz-utils tcpdump xxd libbtrfs-dev libgpgme-dev cargo linux-tools-common heaptrack xxd && \
    sudo apt-get clean && \
    sudo rm -rf /var/lib/apt/lists/*

RUN wget https://ziglang.org/builds/zig-aarch64-linux-0.17.0-dev.263+0add2dfc4.tar.xz && \
    tar -xf zig-aarch64-linux-0.17.0-dev.263+0add2dfc4.tar.xz -C /usr/local/bin --strip-components=1 && \
    rm zig-aarch64-linux-0.17.0-dev.263+0add2dfc4.tar.xz
# this enable memory allocatioin tracking for tests with heaptrack that is donme in the profile build step of franky
# Not needed anymore solved by src/global_allocator.zig 
# RUN sudo sed -i 's|^pub const allocator = allocator_instance.allocator();$|pub const allocator = std.heap.c_allocator;|' /usr/local/bin/lib/std/testing.zig

COPY --chown=agent:agent settings.json /home/agent/.franky/settings.json
RUN wget https://github.com/fr12k/franky/releases/latest/download/franky_${TARGETOS}_${TARGETARCH} && \
    mv franky_${TARGETOS}_${TARGETARCH} /usr/local/bin/franky && \
    chmod +x /usr/local/bin/franky

RUN wget https://github.com/fr12k/soteria-guard/releases/latest/download/soteria-guard_${TARGETOS}_${TARGETARCH} && \
    mv soteria-guard_${TARGETOS}_${TARGETARCH} /usr/local/bin/soteria-guard && \
    chmod +x /usr/local/bin/soteria-guard

    # Non-interactive aliases via scripts in /usr/bin so they work when franky
# invokes bash non-interactively (docker exec, the `bash` tool, etc.).
# See https://www.baeldung.com/ops/dockerfile-set-bash-aliases#setting-aliases-for-the-non-interactive-mode
RUN printf '#!/bin/bash\nclaude --allow-dangerously-skip-permissions --dangerously-skip-permissions "$@"\n' > /usr/bin/claude && \
    chmod +x /usr/bin/claude && \
    printf '#!/bin/bash\nclaude --allow-dangerously-skip-permissions --dangerously-skip-permissions --resume "$@"\n' > /usr/bin/clauder && \
    chmod +x /usr/bin/clauder && \
    printf '#!/bin/bash\nexec ./zig-out/bin/franky --profile ollama-deepseek-flash --role full --yes --mode proxy "$@"\n' > /usr/bin/franky-deepseek && \
    chmod +x /usr/bin/franky-deepseek && \
    printf '#!/bin/bash\nexec ./zig-out/bin/franky --profile ollama-deepseek-kimi-k --role full --yes --mode proxy "$@"\n' > /usr/bin/franky-kimik && \
    chmod +x /usr/bin/franky-kimik

USER agent
RUN go install golang.org/x/vuln/cmd/govulncheck@latest
RUN go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest
RUN cargo install inferno
# Will install franky and settings from the Github Repository in the future.
# COPY --chown=agent:agent franky /usr/local/bin/franky
ENV ZIG_LOCAL_CACHE_DIR=/tmp/zig-cache
ENV ZIG_GLOBAL_CACHE_DIR=/tmp/zig-cache
ENV PATH="/home/agent/.cargo/bin:/home/agent/go/bin:${PATH}"